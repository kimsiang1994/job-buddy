# Copy this file to .env and paste your real key.
# Get a key from the DeepSeek console: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- optional: reach the sites that block automation -------------------------
# Glints, NodeFlair, JobStreet, FastJobs, Indeed and Glassdoor serve a
# Cloudflare challenge or CAPTCHA even to a real browser. Buying the data is
# the workaround; these are the vendors that sell it.

# JSearch -- $25/mo for 10,000 requests, 200/mo free. Singapore supported.
# Carries LinkedIn, Indeed, Glassdoor and ZipRecruiter via Google for Jobs.
JSEARCH_API_KEY=

# Adzuna -- 2,500 hits/mo free, SG supported, no LinkedIn.
# Their terms REQUIRE a "Jobs by Adzuna" attribution wherever results are shown.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Unblocker, for fetching a challenged page directly.
# scrapingbee | scraperapi | zyte | brightdata
SCRAPING_PROVIDER=
SCRAPING_API_KEY=

# --- free partner APIs: broad SG aggregate coverage, no cost ------------------
# Careerjet -- free partner key at careerjet.com/partners/api/
# Aggregates many boards, covers Singapore via the en_SG locale.
CAREERJET_API_KEY=

# Jooble -- free key at jooble.org/api/about, GUID, no card.
JOOBLE_API_KEY=
