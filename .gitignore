# Secrets — never commit real credentials
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# OS / editor cruft
Thumbs.db
Desktop.ini
.DS_Store
.vscode/
.idea/

# Local run artefacts
# usage_log.jsonl is per-machine measurement data, not shared state.
usage_log.jsonl
*.tmp
# Downloaded by fetch_tokenizer.py; several MB, reproducible on demand.
tokenizer/

# Personal source documents. This repo is PUBLIC -- the resume PDF contains a
# real name, personal email, phone number and full employment history. It must
# never be committed. .worktreeinclude does not copy it either; point
# import_resume.py at a local path instead.
input/
profile/master_profile.json
profile/master_profile.draft.json

# User intake. Holds a real name, phone number, salary expectations and the
# archived resume itself. Written by user_input.py from the notebook form.
intake/

# Pipeline run artefacts. All reproducible by re-running, all machine-local.
#   state/sightings.jsonl  is YOUR observation history -- it is the one thing
#   here that cannot be regenerated, but it is also personal job-search data and
#   this repo is public, so it stays local. Back it up separately if you care.
state/
potential applications/

# Claude Code creates isolated worktrees here for parallel work.
# Without this they show up as untracked files in the main checkout.
.claude/worktrees/

# Machine-specific: accumulates "don't ask again" permission rules with absolute
# Windows paths and one-off commands. Useless to anyone else, and this repo is
# public, so it should never be committed.
.claude/settings.json
.claude/settings.local.json

# Experiment results quote the resume back in the graders' reasoning, so they
# carry real employment history. Discovered by scanning before a commit to
# this PUBLIC repo, which is the wrong moment to find out. Results stay local.
experiments/
