{
  "_comment": "The one file you author by hand. Search scopes, hard filters, and scoring weights. Weights are here rather than in code because you will want to retune them after the first real run, and that should not be a code change.",
  "_written_by": "human",
  "_schema_version": 1,
  "filters": {
    "_comment": "Hard filters run BEFORE scoring and before anything costs money. A job that fails one is excluded with a reason, never ranked low.",
    "singapore_only": true,
    "open_only": true,
    "min_salary_sgd_monthly": 8000,
    "allow_unstated_salary": true,
    "max_seniority_gap_below": 2,
    "exclude_companies": [
      "tiktok",
      "bytedance"
    ],
    "exclude_title_patterns": [
      "\\bintern(ship)?\\b",
      "\\bpart[- ]time\\b",
      "\\bsales\\b",
      "\\bteacher\\b|\\btutor\\b",
      "\\bnational jobs\\b"
    ],
    "exclude_agencies": false
  },
  "scopes": [
    {
      "name": "ai-engineer-sg",
      "queries": [
        "machine learning engineer",
        "AI engineer",
        "artificial intelligence engineer"
      ],
      "max_results_per_query": 60
    },
    {
      "name": "ml-platform-sg",
      "queries": [
        "MLOps engineer",
        "machine learning platform",
        "LLM engineer"
      ],
      "max_results_per_query": 40
    },
    {
      "name": "data-science-sg",
      "queries": [
        "data scientist",
        "senior data scientist"
      ],
      "max_results_per_query": 40
    },
    {
      "name": "ai-architect-sg",
      "queries": [
        "AI solutions architect",
        "AI product manager",
        "data engineering manager"
      ],
      "max_results_per_query": 40
    }
  ],
  "profile": {
    "_comment": "Deterministic matching inputs only. The full verified fact store lives in profile/master_profile.json and is built later by import_resume.py.",
    "target_seniority": "senior",
    "years_experience": 5,
    "current_salary_sgd_monthly": null,
    "_skills_comment": "Only skills the resume actually evidences. Adding one you cannot defend in an interview corrupts every downstream score, and later would let the tailoring stage cite it. Tiers: expert = led or built it; working = used it in production; familiar = have touched it.",
    "skills": {
      "expert": [
        "python",
        "sql",
        "llm",
        "rag",
        "prompt engineering",
        "machine learning",
        "artificial intelligence",
        "nlp",
        "etl",
        "data engineering",
        "pyspark",
        "airflow",
        "data warehousing",
        "fine tuning",
        "generative ai"
      ],
      "working": [
        "aws",
        "docker",
        "kubernetes",
        "langchain",
        "vector database",
        "huggingface",
        "bert",
        "deep learning",
        "bayesian modelling",
        "statistics",
        "data governance",
        "stakeholder management",
        "java",
        "hive",
        "presto",
        "data science",
        "data analysis",
        "model deployment",
        "api",
        "microservices",
        "forecasting",
        "clustering",
        "optimisation",
        "experimentation",
        "marketing mix modelling",
        "software engineering"
      ],
      "familiar": [
        "computer vision",
        "openshift",
        "selenium",
        "blockchain",
        "spark",
        "hadoop",
        "gcp",
        "azure",
        "tensorflow",
        "pytorch"
      ]
    }
  },
  "weights": {
    "_comment": "Components that are null for a job (e.g. company_signal before 30 days of history) are dropped and the remaining weights renormalise, rather than being imputed to 50.",
    "skill_match": 30,
    "seniority_fit": 15,
    "comp_signal": 15,
    "competition": 20,
    "company_signal": 10,
    "application_friction": 5,
    "freshness": 5
  },
  "budget": {
    "max_run_cost_usd": 1.0,
    "dev_limit_jobs": 3
  },
  "sources": {
    "_comment": "Which adapters to query. MyCareersFuture alone covers the middle of the SG market but not the top -- its advertising mandate only binds when a foreign work pass is involved, and exempts anything paying over S$22,500/month. 'aggregator' reaches LinkedIn/Indeed/Glassdoor/JobStreet but needs a paid key.",
    "enabled": [
      "mcf",
      "workable",
      "ats",
      "partner",
      "aggregator"
    ],
    "available": [
      "mcf",
      "workable",
      "ats",
      "hn",
      "aggregator"
    ],
    "discover_ats_boards": true,
    "discovery_limit_per_run": 10
  }
}
